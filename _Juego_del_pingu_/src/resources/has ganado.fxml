<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<VBox prefHeight="400.0" prefWidth="640.0" 
      styleClass="root" 
      stylesheets="@PantallaJuego.css" 
      xmlns="http://javafx.com" 
      xmlns:fx="http://javafx.com" 
      fx:controller="vista.PantallaGanador">

  <children>
    <MenuBar VBox.vgrow="NEVER">
      <menus>
        <Menu mnemonicParsing="false" text="Archivo">
          <items>
            <MenuItem mnemonicParsing="false" onAction="#handleReiniciar" text="Volver al Menú" />
          </items>
        </Menu>
      </menus>
    </MenuBar>

    <AnchorPane styleClass="card" VBox.vgrow="ALWAYS">
      <children>
        
        <Text layoutX="120.0" layoutY="160.0" 
              styleClass="big-text" 
              text="¡HAS GANADO!" 
              textAlignment="CENTER" 
              wrappingWidth="400.0">
          <font>
            <Font name="System Bold" size="52.0" />
          </font>
        </Text>

        <Text layoutX="120.0" layoutY="200.0" 
              styleClass="events" 
              text="¡Enhorabuena! Has llegado al final del camino." 
              textAlignment="CENTER" 
              wrappingWidth="400.0" />

        <Button layoutX="220.0" layoutY="260.0" 
                onAction="#handleReiniciar" 
                prefHeight="50.0" 
                prefWidth="200.0" 
                styleClass="primary" 
                text="JUGAR DE NUEVO" />

      </children>
    </AnchorPane>
  </children>
</VBox>
