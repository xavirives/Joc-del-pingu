<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.SeparatorMenuItem?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Text?>

<BorderPane
    xmlns="http://javafx.com/javafx/21.0.10"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="vista.PantallaJuego"
    stylesheets="@PantallaJuego.css"
    styleClass="root">

    <top>
        <MenuBar>
            <menus>
                <Menu mnemonicParsing="false" text="File">
                    <items>
                        <MenuItem fx:id="newGame" mnemonicParsing="false" text="New" onAction="#handleNewGame"/>
                        <SeparatorMenuItem mnemonicParsing="false" />
                        <MenuItem fx:id="saveGame" mnemonicParsing="false" text="Save" onAction="#handleSaveGame"/>
                        <MenuItem fx:id="loadGame" mnemonicParsing="false" text="Load" onAction="#handleLoadGame"/>
                        <SeparatorMenuItem mnemonicParsing="false" />
                        <MenuItem fx:id="quitGame" mnemonicParsing="false" text="Quit" onAction="#handleQuitGame"/>
                    </items>
                </Menu>
            </menus>
        </MenuBar>
    </top>

    <center>
        <StackPane>
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <GridPane fx:id="tablero" gridLinesVisible="true" styleClass="board" prefHeight="520.0">
                <columnConstraints>
                    <ColumnConstraints percentWidth="20.0" />
                    <ColumnConstraints percentWidth="20.0" />
                    <ColumnConstraints percentWidth="20.0" />
                    <ColumnConstraints percentWidth="20.0" />
                    <ColumnConstraints percentWidth="20.0" />
                </columnConstraints>

                <rowConstraints>
                    <RowConstraints percentHeight="10.0" />
                    <RowConstraints percentHeight="10.0" />
                    <RowConstraints percentHeight="10.0" />
                    <RowConstraints percentHeight="10.0" />
                    <RowConstraints percentHeight="10.0" />
                    <RowConstraints percentHeight="10.0" />
                    <RowConstraints percentHeight="10.0" />
                    <RowConstraints percentHeight="10.0" />
                    <RowConstraints percentHeight="10.0" />
                    <RowConstraints percentHeight="10.0" />
                </rowConstraints>

                <children>
                    <!-- Esquinas -->
                    <Text text="Start" styleClass="cell-title" />
                    <Text text="Finish" styleClass="cell-title"
                          GridPane.columnIndex="4" GridPane.rowIndex="9" GridPane.halignment="RIGHT" />

                    <!-- Jugadores: fx:id para Controller + id para CSS -->
                    <Circle fx:id="P1" id="P1" radius="14.0" styleClass="player" />
                    <Circle fx:id="P2" id="P2" radius="14.0" styleClass="player">
                        <GridPane.margin><Insets left="34.0" /></GridPane.margin>
                    </Circle>
                    <Circle fx:id="P3" id="P3" radius="14.0" styleClass="player">
                        <GridPane.margin><Insets left="68.0" /></GridPane.margin>
                    </Circle>
                    <Circle fx:id="P4" id="P4" radius="14.0" styleClass="player">
                        <GridPane.margin><Insets left="102.0" /></GridPane.margin>
                    </Circle>
                </children>
            </GridPane>
        </StackPane>
    </center>

    <bottom>
        <HBox spacing="16" styleClass="bottom-bar">
            <padding>
                <Insets top="16" right="16" bottom="16" left="16"/>
            </padding>

            <!-- Tarjeta Dado -->
            <VBox spacing="10" styleClass="card" prefWidth="280">
                <Label text="Dado" styleClass="card-title" />
                <Text fx:id="dadoResultText" text="Ha salido: -" styleClass="big-text" wrappingWidth="240" />
                <Button fx:id="dado" text="Tirar dado" onAction="#handleDado"
                        maxWidth="Infinity" styleClass="primary" />
            </VBox>

            <!-- Tarjeta Objetos -->
            <VBox spacing="10" styleClass="card" HBox.hgrow="ALWAYS">
                <Label text="Objetos" styleClass="card-title" />

                <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" styleClass="objects-scroll">
                    <content>
                        <VBox spacing="10">
                            <padding>
                                <Insets top="6" right="6" bottom="6" left="6"/>
                            </padding>

                            <HBox alignment="CENTER_LEFT" spacing="10" styleClass="row">
                                <Text fx:id="rapido_t" text="Dado rápido: 0" styleClass="stat" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Button fx:id="rapido" text="Usar" onAction="#handleRapido"/>
                            </HBox>

                            <HBox alignment="CENTER_LEFT" spacing="10" styleClass="row">
                                <Text fx:id="lento_t" text="Dado lento: 0" styleClass="stat" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Button fx:id="lento" text="Usar" onAction="#handleLento"/>
                            </HBox>

                            <HBox alignment="CENTER_LEFT" spacing="10" styleClass="row">
                                <Text fx:id="peces_t" text="Peces: 0" styleClass="stat" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Button fx:id="peces" text="Usar" onAction="#handlePeces"/>
                            </HBox>

                            <HBox alignment="CENTER_LEFT" spacing="10" styleClass="row">
                                <Text fx:id="nieve_t" text="Bolas de nieve: 0" styleClass="stat" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Button fx:id="nieve" text="Usar" onAction="#handleNieve"/>
                            </HBox>

                        </VBox>
                    </content>
                </ScrollPane>
            </VBox>

            <!-- Tarjeta Eventos -->
            <VBox spacing="10" styleClass="card" prefWidth="320">
                <Label text="Eventos" styleClass="card-title" />
                <Text fx:id="eventos" text="Evento ocurrido" styleClass="events" wrappingWidth="280" />
            </VBox>

        </HBox>
    </bottom>

</BorderPane>